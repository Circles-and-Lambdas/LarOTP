{
    "name": "circlesandlambdas/larotp",
    "description": "An OTP generation and Verification Laravel Package using RFC standards.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "otp",
        "hotp",
        "totp",
        "two-factor",
        "2fa",
        "authentication",
        "security"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0",
        "illuminate/notifications": "^10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "dev-main",
        "phpunit/php-code-coverage": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "circlesandlambdas\\larotp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "circlesandlambdas\\larotp\\tests\\": "tests/",
            "App\\Models\\": "tests/Models/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "authors": [
        {
            "name": "Kevin Andeka",
            "email": "andeka.kev@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "circlesandlambdas\\larotp\\LarOTPServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "config": {
        "optimize-autoloader": false,
        "sort-packages": true
    }
}
